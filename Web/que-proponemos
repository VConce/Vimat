    nav a.active, nav a:hover { border-color: var(--brand); color: var(--brand-dark); }
    main { max-width: 1100px; margin: 0 auto; padding: 42px 22px 64px; }
    h1 {
      font-size: clamp(32px, 5vw, 54px);
      line-height: 1.05;
      margin: 0 0 14px;
      letter-spacing: 0;
