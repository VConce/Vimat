    h3 { font-size: 20px; margin: 0 0 8px; }
    p { margin: 0 0 14px; }
    .lead { max-width: 800px; color: #333; font-size: 18px; }
    .section { margin-top: 38px; }
    .split {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 430px);
      gap: 34px;
      align-items: start;
    }
    .hero-img, .media {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 6px;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(245px, 1fr));
      gap: 18px;
    }
    .card {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: #fff;
      padding: 18px;
      min-height: 100%;
    }
    .card img {
      width: 100%;
      aspect-ratio: 16 / 10;
      object-fit: cover;
      border-radius: 6px;
      margin: 0 0 14px;
      background: var(--soft);
    }
    .muted { color: var(--muted); }
    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 9px 16px;
      margin-top: 10px;
      background: var(--brand);
      color: #fff;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 700;
      border: 0;
      cursor: pointer;
    }
    .button:hover { background: var(--brand-dark); }
    .button.secondary {
      color: var(--brand-dark);
      background: #e8f3f6;
    }
    .topic-list {
      columns: 2 360px;
      column-gap: 38px;
      padding-left: 22px;
    }
    .topic-list li { break-inside: avoid; margin: 0 0 9px; }
    .downloads {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 12px;
      margin-top: 16px;
    }
    form {
      display: grid;
      gap: 14px;
      max-width: 680px;
      margin-top: 24px;
    }
    label { display: grid; gap: 6px; font-weight: 700; }
    input, textarea {
      width: 100%;
      border: 1px solid #cfcfcf;
      border-radius: 6px;
      padding: 11px 12px;
      font: inherit;
    }
    textarea { min-height: 160px; resize: vertical; }
    footer {
      border-top: 1px solid var(--line);
      background: var(--soft);
      color: #333;
    }
    .foot {
      max-width: 1100px;
      margin: 0 auto;
      padding: 24px 22px;
      display: flex;
      flex-wrap: wrap;
      gap: 12px 28px;
      justify-content: space-between;
      font-size: 14px;
    }
    @media (max-width: 760px) {
      .bar { align-items: flex-start; flex-direction: column; }
      nav { justify-content: flex-start; }
      main { padding-top: 30px; }
      .split { grid-template-columns: 1fr; }
    }
