    }
    header {
      border-bottom: 1px solid var(--line);
      background: #fff;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .bar {
      max-width: 1100px;
      margin: 0 auto;
      padding: 18px 22px;
